# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# =============================================================================
# Virtual Environments
# =============================================================================
venv/
env/
.env/
.venv/

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
# IDE / Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Data — large files, keep out of version control
# =============================================================================
data/raw/*
data/processed/*
data/metadata/*.csv
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/metadata/.gitkeep

# =============================================================================
# Model Checkpoints & Outputs
# =============================================================================
outputs/models/*.pth
outputs/models/*.pt
outputs/models/*.ckpt
outputs/figures/*
outputs/gradcam/*
outputs/network/*
!outputs/models/.gitkeep
!outputs/figures/.gitkeep
!outputs/gradcam/.gitkeep
!outputs/network/.gitkeep

# =============================================================================
# Miscellaneous
# =============================================================================
*.log
*.DS_Store
Thumbs.db
wandb/
mlruns/
